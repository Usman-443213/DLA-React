</footer>

<script>
let cur=0;const slides=document.querySelectorAll(".hero-slide"),dots=document.querySelectorAll(".slide-dot"),bar=document.getElementById("slideProgress");let st=null;
function goToSlide(n){slides[cur].classList.remove("active");dots[cur].classList.remove("active");cur=n;slides[cur].classList.add("active");dots[cur].classList.add("active");resetProg();}
function nextSlide(){goToSlide((cur+1)%slides.length);}
function resetProg(){bar.style.transition="none";bar.style.width="0%";bar.offsetHeight;bar.style.transition="width 4s linear";bar.style.width="100%";clearTimeout(st);st=setTimeout(nextSlide,4000);}
resetProg();
function playVideo(){document.getElementById("vidBox").innerHTML='<iframe src="https://www.youtube.com/embed/YOUR_VIDEO_ID?autoplay=1" allow="autoplay;fullscreen" allowfullscreen style="width:100%;height:100%;border:none;display:block"></iframe>';}
const SHEET_URL="https://script.google.com/macros/s/AKfycbyJMHZ-XfDZiIU8qsph9XIqXsT0ZiHYb79e-vVUWhFOkTHfR2oaDVYsvfvYuwk6uiPZ/exec";
async function submitForm(e){
  e.preventDefault();
  const form=document.getElementById("leadForm");
  const btn=document.querySelector(".submit-btn");
  btn.innerHTML='<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-dasharray="31.4" stroke-dashoffset="10"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></circle></svg> Sending...';
  btn.disabled=true;
  const data={firstName:form.firstName.value,lastName:form.lastName.value,phone:form.phone.value,email:form.email.value,timeline:form.timeline.value,message:form.message.value};
  try{
    await fetch(SHEET_URL,{method:"POST",mode:"no-cors",headers:{"Content-Type":"application/json"},body:JSON.stringify(data)});
    btn.innerHTML='<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Submitted! We\'ll be in touch shortly.';
    btn.style.background="#2a7a4b";btn.style.color="#fff";form.reset();
  }catch(err){
    btn.innerHTML='<svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> Error — please try again';
    btn.style.background="#9b2c2c";btn.style.color="#fff";btn.disabled=false;
  }
}
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add("visible");});},{threshold:.1});
document.querySelectorAll(".reveal,.how-card,.p-tile,.pr-card,.chk-list li").forEach(el=>{el.classList.add("reveal");obs.observe(el);});
function toggleMenu(){
  document.querySelector('.ham-btn').classList.toggle('open');
  document.getElementById('navLinks').classList.toggle('open');
}
document.querySelectorAll('#navLinks a').forEach(a=>{
  a.addEventListener('click',()=>{
    document.querySelector('.ham-btn').classList.remove('open');
    document.getElementById('navLinks').classList.remove('open');
  });
});
document.addEventListener('click',e=>{
  const nav=document.getElementById('navLinks');
  const btn=document.querySelector('.ham-btn');
  if(nav&&nav.classList.contains('open')&&!nav.contains(e.target)&&!btn.contains(e.target)){
    nav.classList.remove('open');btn.classList.remove('open');
  }
});
</script>
</body>
</html>